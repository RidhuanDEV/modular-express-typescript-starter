# APP CONFIG
PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_to_a_random_string_at_least_32_chars

# SEQUELIZE CONNECTION
# Use 'localhost' for local development (npm run dev)
# Use 'mysql' if running the app via Docker (docker compose up)
DATABASE_URL=mysql://root:password@localhost:3306/myapp

# REDIS CONNECTION
# Use 'localhost' for local development (npm run dev)
# Use 'redis' if running the app via Docker (docker compose up)
REDIS_URL=redis://localhost:6379

# DOCKER INITIALIZATION
# These must match the credentials in the connection URLs above
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=myapp